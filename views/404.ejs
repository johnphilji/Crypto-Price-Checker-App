<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>404 — Page Not Found</title>
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    .notfound-container {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 80vh;
      text-align: center;
      padding: 2rem;
    }
    .err-code {
      font-family: 'DM Serif Display', serif;
      font-size: 8rem;
      color: var(--gold);
      line-height: 1;
      margin-bottom: 1rem;
    }
    .err-title {
      font-family: 'Epilogue', sans-serif;
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 1rem;
    }
    .err-desc {
      color: var(--text-secondary);
      max-width: 400px;
      margin-bottom: 2rem;
    }
    .btn-home {
      display: inline-block;
      background: var(--gold);
      color: var(--text-inverse);
      padding: 0.8rem 2rem;
      text-decoration: none;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-size: 0.8rem;
      transition: filter 0.2s;
    }
    .btn-home:hover { filter: brightness(1.1); }
  </style>
</head>
<body>
  <div class="notfound-container">
    <div class="err-code">404</div>
    <div class="err-title">Lost in Space</div>
    <p class="err-desc">
      The ticker or page you're looking for doesn't exist on this terminal. 
      Let's get you back to the market dashboard.
    </p>
    <a href="/" class="btn-home">Return to Dashboard</a>
  </div>
</body>
</html>
