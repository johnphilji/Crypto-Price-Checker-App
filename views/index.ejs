<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CryptoScope — Professional Market Data</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <!-- ═══════════════════════════════ HEADER ═══ -->
  <header class="site-header">
    <div class="header-bar">

      <a href="/" class="logo">
        <span class="logo-mark">CryptoScope</span>
        <span class="logo-divider"></span>
        <span class="logo-sub">Market Data</span>
      </a>

      <!-- Mini Ticker Tape -->
      <div class="header-tickers" id="headerTickers">
        <% if (popularData && popularData.length > 0) { %>
          <% popularData.slice(0,5).forEach(coin => { %>
          <div class="tick-item">
            <span class="tick-sym"><%= coin.symbol.split('-')[0] %></span>
            <span class="tick-val">$<%= coin.last ? Number(coin.last).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) : '—' %></span>
            <% if (coin.change !== null) { %>
            <span class="tick-chg <%= parseFloat(coin.change) >= 0 ? 'pos' : 'neg' %>">
              <%= parseFloat(coin.change) >= 0 ? '+' : '' %><%= coin.change %>%
            </span>
            <% } %>
          </div>
          <% }) %>
        <% } %>
      </div>

      <!-- Controls -->
      <div class="header-controls">
        <div class="live-pill">
          <span class="live-dot"></span>
          <span>Live</span>
        </div>

        <label class="theme-toggle" title="Toggle theme">
          <div class="toggle-track" id="toggleTrack">
            <input type="checkbox" id="themeCheck" autocomplete="off" />
            <div class="toggle-knob" id="toggleKnob">
              <span id="toggleIcon">☾</span>
            </div>
          </div>
          <span class="toggle-label" id="toggleLabel">Dark</span>
        </label>
      </div>

    </div>
  </header>

  <!-- ═══════════════════════════════ HERO ═══ -->
  <section class="hero">
    <div class="hero-inner">

      <div class="hero-text">
        <div class="hero-eyebrow">
          <span class="eyebrow-line"></span>
          <span class="eyebrow-text">Blockchain.com Exchange API</span>
        </div>
        <h1 class="hero-h1">
          Real&#8209;time prices<br/>
          for every <em>digital asset</em><br/>
          you trade.
        </h1>
        <p class="hero-desc">
          Professional-grade market data sourced directly from
          Blockchain.com's exchange. Search any trading pair for
          live price, 24&#8209;hour range, volume, and momentum indicators.
        </p>
      </div>

      <!-- Search Panel -->
      <div class="search-panel">
        <div class="panel-header">
          <span class="panel-title">Price Lookup Terminal</span>
          <div class="panel-dots">
            <span class="panel-dot"></span>
            <span class="panel-dot"></span>
            <span class="panel-dot"></span>
          </div>
        </div>

        <div class="panel-body">
          <form action="/search" method="POST" id="searchForm">
            <div class="field-group">
              <label class="field-label" for="symbolInput">Trading Pair</label>
              <div class="input-row">
                <span class="input-pre">PAIR /</span>
                <input
                  id="symbolInput"
                  type="text"
                  name="symbol"
                  placeholder="BTC, ETH, SOL…"
                  value="<%= searchSymbol ? searchSymbol.replace('-USD','') : '' %>"
                  autocomplete="off"
                  spellcheck="false"
                  autofocus
                />
              </div>
              <div class="quick-chips">
                <span class="q-chip" onclick="fillSymbol('BTC')">BTC</span>
                <span class="q-chip" onclick="fillSymbol('ETH')">ETH</span>
                <span class="q-chip" onclick="fillSymbol('SOL')">SOL</span>
                <span class="q-chip" onclick="fillSymbol('XRP')">XRP</span>
                <span class="q-chip" onclick="fillSymbol('ADA')">ADA</span>
                <span class="q-chip" onclick="fillSymbol('BNB')">BNB</span>
              </div>
            </div>

            <button class="search-submit" type="submit">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
              Fetch Market Data
            </button>
          </form>
        </div>

        <div class="panel-footer">
          Enter a coin symbol — USD pair appended automatically
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════ MAIN ═══ -->
  <main class="main-content">

    <!-- Alert: error -->
    <% if (searchError) { %>
    <div class="alert alert-error">
      <span>⚠&nbsp;&nbsp;<%= searchError %></span>
    </div>
    <% } %>

    <!-- ─── Search Result ─────────────────── -->
    <% if (searchResult) { %>
    <section class="result-section">
      <div class="section-head">
        <div>
          <span class="section-kicker">Search Result</span>
          <span class="section-title"><%= searchResult.symbol %></span>
        </div>
        <span class="section-meta">Blockchain.com Exchange · USD Pair</span>
      </div>

      <div class="result-card" id="resultCard">

        <div class="result-top">
          <div class="coin-avatar">
            <div class="coin-avatar-text"><%= searchResult.symbol.split('-')[0] %></div>
          </div>
          <div>
            <div class="coin-full-sym"><%= searchResult.symbol %></div>
            <div class="coin-pair-sub">
              Quoted in <%= searchResult.symbol.split('-')[1] || 'USD' %> &middot;
              Blockchain.com Exchange
            </div>
          </div>
          <div class="price-display">
            <div class="price-num" id="livePrice">
              $<%= searchResult.last
                ? Number(searchResult.last).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 6})
                : 'N/A' %>
            </div>
            <% if (searchResult.change !== null && searchResult.change !== undefined) { %>
            <div class="chg-badge <%= parseFloat(searchResult.change) >= 0 ? 'pos' : 'neg' %>" id="liveChg">
              <%= parseFloat(searchResult.change) >= 0 ? '▲' : '▼' %>
              <%= Math.abs(searchResult.change) %>%
              <span style="opacity:.6;font-size:.6rem;margin-left:.15rem">24H</span>
            </div>
            <% } %>
          </div>
        </div>

        <div class="result-stats">
          <div class="r-stat">
            <div class="r-stat-lbl">24h Open</div>
            <div class="r-stat-val">
              $<%= searchResult.open24h
                ? Number(searchResult.open24h).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 6})
                : 'N/A' %>
            </div>
          </div>
          <div class="r-stat">
            <div class="r-stat-lbl">Volume 24h</div>
            <div class="r-stat-val"><%= formatNumber(searchResult.volume24h) %></div>
          </div>
        </div>



        <div class="result-foot">
          <span class="result-src">
            Source: <a href="https://api.blockchain.com/v3/exchange/tickers/<%= searchResult.symbol %>" target="_blank" rel="noopener">
              api.blockchain.com/v3/exchange/tickers/<%= searchResult.symbol %>
            </a>
          </span>
          <button class="btn-refresh" onclick="refreshTicker('<%= searchResult.symbol %>', this)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 4v6h-6"/><path d="M1 20v-6h6"/><path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/></svg>
            Refresh
          </button>
        </div>
      </div>
    </section>
    <% } %>

    <!-- ─── Market Table ───────────────────── -->
    <section class="market-section">
      <div class="section-head">
        <div>
          <span class="section-kicker">Market Overview</span>
          <span class="section-title">Popular Trading Pairs</span>
        </div>
        <span class="section-meta"><%= popularData.length %> pairs · USD quoted</span>
      </div>

      <% if (popularData.length > 0) { %>
      <table class="market-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Asset</th>
            <th>Last Price</th>
            <th>24h Change</th>
            <th>Volume</th>
          </tr>
        </thead>
        <tbody>
          <% popularData.forEach((coin, i) => {
            let pct = 50;
            if (coin.high24h && coin.low24h && coin.last && (coin.high24h - coin.low24h) > 0) {
              pct = Math.min(100, Math.max(0,
                ((coin.last - coin.low24h) / (coin.high24h - coin.low24h)) * 100
              ));
            }
            const isPos = coin.change !== null && parseFloat(coin.change) >= 0;
          %>
          <tr style="animation-delay:<%= i * 60 %>ms">
            <td class="td-idx"><%= i + 1 %></td>
            <td>
              <div class="td-coin-wrap">
                <div class="coin-dot"><%= coin.symbol.split('-')[0].substring(0,4) %></div>
                <div>
                  <div class="coin-primary"><%= coin.symbol.split('-')[0] %></div>
                  <div class="coin-secondary"><%= coin.symbol %></div>
                </div>
              </div>
            </td>
            <td class="td-price">
              $<%= coin.last
                ? Number(coin.last).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2})
                : '—' %>
            </td>
            <td class="td-chg <%= coin.change !== null ? (isPos ? 'pos' : 'neg') : '' %>">
              <% if (coin.change !== null) { %>
                <%= isPos ? '+' : '' %><%= coin.change %>%
              <% } else { %>—<% } %>
            </td>
            <td><%= formatNumber(coin.volume24h) %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      <% } else { %>
      <div class="alert alert-info">
        ℹ&nbsp;&nbsp;Market data temporarily unavailable — the API may be rate-limiting requests.
      </div>
      <% } %>
    </section>

    <!-- ─── How It Works ──────────────────── -->
    <section class="how-section">
      <div class="section-head">
        <div>
          <span class="section-kicker">Architecture</span>
          <span class="section-title">How It Works</span>
        </div>
        <span class="section-meta">Express · Axios · EJS · Blockchain.com API</span>
      </div>

      <div class="how-grid">
        <div class="how-step">
          <div class="step-num">01</div>
          <div class="step-tag">Client</div>
          <div class="step-title">You Submit a Symbol</div>
          <div class="step-desc">
            Enter a ticker like <code>BTC</code> or <code>ETH-USD</code>
            in the search panel. The form POSTs to the Express server.
          </div>
        </div>
        <div class="how-step">
          <div class="step-num">02</div>
          <div class="step-tag">Express.js</div>
          <div class="step-title">Server Routes the Request</div>
          <div class="step-desc">
            The <code>POST /search</code> route in <code>server.js</code>
            validates and normalises the symbol, appending <code>-USD</code>
            if needed.
          </div>
        </div>
        <div class="how-step">
          <div class="step-num">03</div>
          <div class="step-tag">Axios</div>
          <div class="step-title">API Call via Axios</div>
          <div class="step-desc">
            Axios fetches <code>api.blockchain.com/v3/exchange/tickers/{symbol}</code>
            and awaits the JSON payload with price, volume and range data.
          </div>
        </div>
        <div class="how-step">
          <div class="step-num">04</div>
          <div class="step-tag">EJS</div>
          <div class="step-title">Template Renders Data</div>
          <div class="step-desc">
            The EJS view receives the parsed data object and renders
            it into this page — sent back to your browser as HTML.
          </div>
        </div>
      </div>
    </section>

  </main>

  <!-- ═══════════════════════════════ FOOTER ═══ -->
  <footer class="site-footer">
    <div class="footer-inner">
      <span class="footer-brand">CryptoScope</span>
      <div class="footer-stack">
        <span class="stack-tag">Node.js</span>
        <span class="stack-tag">Express</span>
        <span class="stack-tag">Axios</span>
        <span class="stack-tag">EJS</span>
        <span class="stack-tag">Blockchain.com API</span>
      </div>
      <span class="footer-copy">For educational purposes only. Not financial advice.</span>
    </div>
  </footer>

  <script src="/js/app.js"></script>
</body>
</html>
